                        <tr bgcolor=\"#ffffff\">\r\n                                <td width=\"100%\" height=\"30\"></td>\r\n                            </tr>\r\n\r\n                            <tr id=\"simple-content-row\" bgcolor=\"#ffffff\">\r\n                                <td width=\"100%\">\r\n                                    <table align=\"right\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\r\n                                        <tbody>\r\n                                            <tr>\r\n                                                <td width=\"7%\"></td>\r\n                                                <td width=\"86%\">\r\n\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t<tbody>\r\n\r\n                                                            <tr>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<td width=\"100%\" class=\"article-title\" style=\"text-align: right; font-size: 18px;  line-height: 24px;  color: #231f20;  margin-top: 0px;  padding-bottom: 18px; font-family: HelveticaNeue, sans-serif;\">\r\n                                                                    <p style=\"white-space:pre-wrap;\">מצורף מכתב המפרט את יתרות חוב/זכות למוסד חינוכי לביא\r\nלפתיחת הקובץ המצורף נדרש להזין את תעודת הזהות שלך.\r\nבברכה צוות מוסד חינוכי לביא.\r\n\r\nלחיצה על פתיחת הקובץ מהווה את הסכמתך לקבל מסמך בדואר אלקטרוני.\r\nההודעה נשלחה באמצעות מערכת PaySchool  מבית ONE City</p>\r\n\r\n                                                                              <p style=\"font-size: 16px;\"> לפתיחת הקובץ <a href=\"https://general-api.payschool.co.il/api/v1/external/report/0?id�95&municipalityExternalIdRf7f496-569c-42f0-a4ad-a99b862955bb&externalReportType=2\" style=\"color: #1155CC\">לחץ/י כאן</a></p>\r\n\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t</td></tr>\r\n                                                            <tr><td width=\"100%\" height=\"10\"></td></tr>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t</tbody>\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t</table>\r\n\r\n                                                </td>\r\n                                                <td width=\"7%\"></td>\r\n                                            </tr>\r\n                                        </tbody>\r\n                                    </table>\r\n                                </td>\r\n                            </tr>\r\n\r\n                            <tr bgcolor=\"#ffffff\">\r\n                                <td width=\"100%\" height=\"15\"></td>\r\n                            </tr>\r\n\t\t\t\t\t\t\t<tr>\r\n                                <td width=\"100%\" height=\"19\"></td>\r\n                            </tr>\r\n\r\n                            <tr>\r\n                                <td width=\"100%\" height=\"13\"></td>\r\n                            </tr>\r\n\r\n\r\n                        </tbody>\r\n                    </table>\r\n                </td>\r\n            </tr>\r\n        </tbody>\r\n    </table><img src=\"https://mandrillapp.com/track/open.php?u1081645&id\fc91462274541a7873e013ddc760ac3\" height=\"1\" width=\"1\" alt=\"\">",
